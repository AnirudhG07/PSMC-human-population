diff --git a/src/phlash/mcmc.py b/src/phlash/mcmc.py
index b507278..ea9e407 100644
--- a/src/phlash/mcmc.py
+++ b/src/phlash/mcmc.py
@@ -91,6 +91,18 @@ def fit(
     )
     # to conserve memory, we get rid of data at this point
     del data
+
+    # Filter out chunks that are all missing in the data part. The GPU kernel
+    # requires that every observation has at least one valid site.
+    valid_chunks = chunks[:, overlap:].max(axis=1) > -1
+    if not np.all(valid_chunks):
+        num_invalid = len(chunks) - np.sum(valid_chunks)
+        logger.info("Filtering out {} chunks with all missing values", num_invalid)
+        chunks = chunks[valid_chunks]
+    
+    if len(chunks) == 0:
+        raise ValueError("No valid data chunks found after filtering missing values.")
+
     # the mutation rate per generation, if known.
     mutation_rate = options.get("mutation_rate")
     # if we know the true dm, just use its mutation rate
diff --git a/src/phlash/psmc.py b/src/phlash/psmc.py
